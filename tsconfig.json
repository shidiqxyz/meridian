{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "vitest"],
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "declaration": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  },
  "include": ["src/**/*", "scripts/**/*.ts", "test/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist", "discord-listener"]
}
